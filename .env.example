# --- General ---
COMPOSE_PROJECT_NAME=llm_translate

# --- Postgres ---
POSTGRES_USER=translator
POSTGRES_PASSWORD=change_me
POSTGRES_DB=translator
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_BROKER_DB=0
REDIS_BACKEND_DB=1

# --- vLLM / ML service (запускается на CPU, без квантизации) ---
MODEL_NAME=Qwen/Qwen3.5-0.8B
VLLM_HOST=vllm
VLLM_PORT=8000
VLLM_MAX_MODEL_LEN=8192
VLLM_CPU_KVCACHE_SPACE=4
ML_MAX_NEW_TOKENS=1024
ML_REQUEST_TIMEOUT=180
HUGGING_FACE_HUB_TOKEN=

# --- Backend ---
BACKEND_PORT=8000
LOG_LEVEL=INFO
CELERY_WORKER_CONCURRENCY=2

# --- Frontend ---
FRONTEND_PORT=5173

# --- Proxy ---
PROXY_PORT=80
RATE_LIMIT_RPM=5

# --- Monitoring ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me
